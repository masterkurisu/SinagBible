#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/Users/chrisdomingo/Documents/Coding-projects/Sinag Bible mobile/node_modules/.pnpm/@sentry+cli@2.58.4/node_modules/@sentry/cli/node_modules:/Users/chrisdomingo/Documents/Coding-projects/Sinag Bible mobile/node_modules/.pnpm/@sentry+cli@2.58.4/node_modules:/Users/chrisdomingo/Documents/Coding-projects/Sinag Bible mobile/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/Users/chrisdomingo/Documents/Coding-projects/Sinag Bible mobile/node_modules/.pnpm/@sentry+cli@2.58.4/node_modules/@sentry/cli/node_modules:/Users/chrisdomingo/Documents/Coding-projects/Sinag Bible mobile/node_modules/.pnpm/@sentry+cli@2.58.4/node_modules:/Users/chrisdomingo/Documents/Coding-projects/Sinag Bible mobile/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../bin/sentry-cli" "$@"
else
  exec node  "$basedir/../../bin/sentry-cli" "$@"
fi
